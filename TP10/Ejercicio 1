matriz2 = []
valor = 27

for i in range(n):
    fila = []

    for l in range(n):
        if i + l == n - 1:
            fila.append(valor)
            valor //= 3
        else:
            fila.append(0)

    matriz2.append(fila)
imprimirmatriz(matriz2)
