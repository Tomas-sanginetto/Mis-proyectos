# Se desea ingresar la nota de 5 alumnos y mostrar su promedio

suma = 0

for contador in range(1, 6):
    nota = float(input("Ingrese la nota del alumno: "))

    while nota < 1 or nota > 10:
        print("Nota invalida. Debe estar entre 1 y 10.")
        nota = float(input("Ingrese la nota del alumno: "))

    suma += nota

promedio = suma / 5
print("El promedio de los 5 alumnos es: ", promedio)

