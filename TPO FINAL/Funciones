        indice = seleccionar_opcion(opciones, Fore.GREEN + "Que desea hacer?") # Dentro del while porque sino seria un ciclo infinito


def agregar_genero_pelicula(lst_generos, lst_generos_disponibles, indice_pelicula):
    '''Muestra los generos del catalogo que la pelicula todavia no tiene y agrega el elegido (o uno nuevo) a esa pelicula'''
    generos_disponibles_pelicula = []
    for i in range(len(lst_generos_disponibles)):
        if lst_generos_disponibles[i] not in lst_generos[indice_pelicula]: # Revisa 1x1 los elementos internamente
            generos_disponibles_pelicula.append(lst_generos_disponibles[i])

    generos_disponibles_pelicula.append("Agregar nuevo genero")
    indice = seleccionar_opcion(generos_disponibles_pelicula, "Seleccione el genero a agregar:")
    if indice == len(generos_disponibles_pelicula) - 1:
        nuevo = crear_genero_nuevo(lst_generos_disponibles)
        lst_generos[indice_pelicula].append(nuevo)
    else:
        lst_generos[indice_pelicula].append(generos_disponibles_pelicula[indice])
    print("Genero agregado con exito!")

    
def quitar_genero_pelicula(lst_generos, indice_pelicula):
    '''Permite quitar un genero de una pelicula con confirmacion, validando que siempre quede al menos un genero'''
    if len(lst_generos[indice_pelicula]) <= 1:
        print(Fore.RED + "La pelicula debe tener al menos un genero, no se puede quitar")
        return
    
    indice = seleccionar_opcion(lst_generos[indice_pelicula], "Seleccione el genero a quitar:")
    genero_elegido = lst_generos[indice_pelicula][indice] # LISTA DE LISTAS
    confirmacion = input(f"Esta seguro que desea quitar el genero '{genero_elegido}'? (S/N): ")
    while confirmacion.upper() != "S" and confirmacion.upper() != "N":
        print(Fore.RED + "Opcion invalida.")
        confirmacion = input("Esta seguro? (S/N): ")
    if confirmacion.upper() == "S":
        lst_generos[indice_pelicula].pop(indice)
        print("Genero eliminado con exito!")
    else:
        print("Eliminacion cancelada.")

def crear_genero_nuevo(lst_generos_disponibles):
    '''Valida que no se ingrese un genero vacio ni repetido y lo agrega al catalogo'''
    nombre = input("Ingrese el nuevo genero:").strip() # quita espacios y los valida el while 
    while nombre == "" or genero_existe(nombre, lst_generos_disponibles):
        if nombre == "":
            print(Fore.RED + "No puede ser un genero vacio, ingrese nuevamente!")
        else:
            print(Fore.RED + "Genero ya existente")
        nombre = input("Intente con otro genero:").strip() # Quita espacios
    lst_generos_disponibles.append(nombre)
    return nombre


# Muy parecida a titulo_existe pero con generos
def genero_existe(genero, lst_generos_disponibles):
    '''Valida que no haya un genero repetido'''
    genero = genero.strip().lower()
    for i in range(len(lst_generos_disponibles)):
        if lst_generos_disponibles[i].strip().lower() == genero:
            return True
    return False 


def seleccionar_opcion(lista, mensaje):
    '''Muestra la lista numerada junto con un mensaje, valida que el usuario
    ingrese un numero dentro del rango valido y retorna el indice
    correspondiente a la opcion elegida'''
    print(mensaje)
    for i in range(len(lista)):
        print(f"{i + 1} {lista[i]}") # Muestra el valor humano y el indice "Lenguaje Python (El 1 es el cero)"
    num = input("Ingrese el numero: ")
    while num.isdigit() == False or int(num) < 1 or int(num) > len(lista):
        print(Fore.RED + "Numero invalido, intentelo nuevamente")
        num = input("Ingrese el numero: ")
    return int(num) - 1 # Menos 1, por el indice inicial de las listas de Python [0]
