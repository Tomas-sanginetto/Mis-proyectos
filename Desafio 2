# Caracteres que se ignoran al leer el archivo (generados por el sistema
# operativo o por el usuario al formatear el texto)
ESPACIOS = (" ", "\t", "\r", "\n")

# Únicos caracteres aceptados según la consigna
VALIDOS = ("L", "R", "C")


def limpiar_y_validar(contenido):
    """Procesa el contenido del archivo carácter por carácter.

    Ignora espacios, tabs y saltos de línea automáticamente.
    Acepta mayúsculas y minúsculas convirtiendo todo a mayúsculas.
    Recolecta todos los caracteres inválidos encontrados (sin repetir).

    Args:
        contenido (str): Texto crudo leído desde el archivo.

    Returns:
        tuple: (secuencia_limpia, invalidos)
            - secuencia_limpia (str): solo L, R, C en mayúsculas.
            - invalidos (list): lista de caracteres inválidos únicos encontrados.
    """
    secuencia = ""
    invalidos = []
    for caracter in contenido.upper():
        if caracter in VALIDOS:
            secuencia += caracter
        elif caracter in ESPACIOS:
            # Los espacios y saltos de línea se ignoran sin error
            continue
        else:
            # Recolecta inválidos únicos sin detener el recorrido
            if caracter not in invalidos:
                invalidos.append(caracter)
    return secuencia, invalidos


def cargar_secuencia():
    """Solicita al usuario la ruta de un archivo .txt y retorna la secuencia validada.

    Funciona en cualquier entorno (VSCode, Thonny, IDLE, terminal, etc.)
    usando rutas absolutas o relativas estándar de Python sin bibliotecas externas.
    El .strip('"') maneja el caso de Windows donde al copiar la ruta
    el sistema agrega comillas automáticamente.

    Returns:
        str: Secuencia de caracteres L, R y C en mayúsculas.
    """
    while True:
        # .strip('"') elimina las comillas que Windows agrega al copiar rutas
        ruta = input("Ruta del archivo (.txt): ").strip().strip('"')

        if not ruta.endswith(".txt"):
            print("Error: el archivo debe tener extensión .txt")
            print("Intente nuevamente.\n")
            continue

        try:
            archivo = open(ruta, "r")
            contenido = archivo.read()
            archivo.close()
        except FileNotFoundError:
            print("Error: no se encontró el archivo en esa ruta.")
            print("Verifique que la ruta sea correcta y que el archivo exista.")
            print("Intente nuevamente.\n")
            continue

        secuencia, invalidos = limpiar_y_validar(contenido)

        if len(invalidos) == 1:
            print(f"Error: el archivo contiene el carácter inválido '{invalidos[0]}'.")
            print("Solo se permiten L (izquierda), R (derecha) y C (centro).")
            print("Intente nuevamente.\n")
            continue
        elif len(invalidos) > 1:
            print(f"Error: el archivo contiene {len(invalidos)} caracteres inválidos (solo se permiten L, R y C).")
            print("Intente nuevamente.\n")
            continue

        if len(secuencia) == 0:
            print("Error: el archivo está vacío. Ingrese una secuencia válida.")
            print("Intente nuevamente.\n")
            continue

        if len(secuencia) > 1000:
            print(f"Error: la secuencia tiene {len(secuencia)} caracteres.")
            print("El máximo permitido es 1000.")
            print("Intente nuevamente.\n")
            continue

        return secuencia


