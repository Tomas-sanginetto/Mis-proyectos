# Ingresar la edad de dos hermanos e indicar quien es el mayor o si son mellizos

hermano1 = int(input("Ingresar la edad del primer hermano:"))
hermano2 = int(input("Ingresar la edad del segundo hermano:"))

if hermano1 > hermano2:
    print("El primer hermano es mayor que el segundo")
elif hermano1 < hermano2:
    print("El segundo hermano es mayor que el primero")
else:
    print("Son mellizos")

