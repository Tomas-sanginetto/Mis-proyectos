# Escribir una funcion para devolver la posicion que ocupa un valor ingresado por parametro
# Usar busqueda Secuencial en una lista desordenada
# La funcion debe devolver -1 si el elemento no se encuentra en la lista


def ingresar_datos(n):
    lista = []
    for i in range(n):
        valor = int(input("Ingrese un valor:"))
        lista.append(valor)  # Lo agrega a la lista vacia
    return lista


def busqueda_secuencial(lista, valor):
    i = 0
    posicion = -1
    while i < len(lista) and posicion == -1:
        if lista[i] == valor:
            posicion = i
        i += 1
    return posicion


def main():
    n = int(input("Ingrese la cantidad de numeros que quiere cargar en la lista:"))
    lista = ingresar_datos(n)
    print("La lista ingresada fue:", lista)

    valor = int(input("Ingrese el valor que quiere buscar en la lista:"))
    posicion = busqueda_secuencial(lista, valor)

    if posicion == -1:
        print("-1")
    else:
        print("El valor", valor, "se encuentra en la posicion", posicion)


main()
