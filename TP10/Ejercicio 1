# TP10
# A
n = int(input("Ingrese tamaño de una matriz:"))
matriz = []
valor = 1
for f in range(n):
    fila = []
    for i in range(n):
        if f == i:
            fila.append(valor)
            valor += 2
        else:
            fila.append(0)
    matriz.append(fila)


def imprimirmatriz(matriz):
    filas = len(matriz)
    columnas = len(matriz)
    for x in range(filas):
        for d in range(columnas):
            print("%3d" % matriz[x][d], end='')
        print()
imprimirmatriz(matriz)

print("="*40)
