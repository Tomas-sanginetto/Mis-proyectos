# Programa que calcule y muestre el sueldo neto de un empleado en base a su sueldo basico y antiguedad (años)
# S = +5% de salario bruto por cada año de antiguedad
# C = +7% de salario bruto por cada año de antiguedad
# Descuentos = Jubilacion 11% ; Obra social 3% ; Sindicato 3%
sueldoNeto = 0

sueldoBasico = float(input("Ingrese su sueldo basico: $"))
antiguedad = int(input("Ingrese su antiguedad (En años):"))
estadoCivil = input("Ingrese su estado civil (S/C):")

while sueldoBasico <= 0:
    print("Sueldo no valido, intentelo nuevamente!")
    sueldoBasico = float(input("Ingrese su sueldo basico: $"))

while antiguedad < 0:
    print("Antiguedad invalida, intentelo denuevo")
    antiguedad = int(input("Ingrese su antiguedad (En años):"))

while estadoCivil != "C" and estadoCivil != "S":
    print("Ingrese bien el estado civil, intente otra vez")
    estadoCivil = input("Ingrese su estado civil (S/C):")

if estadoCivil == "S":
    sueldoNeto = sueldoBasico + (sueldoBasico * 0.05 * antiguedad)
    sueldoNeto = sueldoNeto * 0.89
    sueldoNeto = sueldoNeto * 0.97
    sueldoNeto = sueldoNeto * 0.97
else:
    sueldoNeto = sueldoBasico + (sueldoBasico * 0.07 * antiguedad)
    sueldoNeto = sueldoNeto * 0.89
    sueldoNeto = sueldoNeto * 0.97
    sueldoNeto = sueldoNeto * 0.97

print("Su sueldo neto es: $", sueldoNeto) 

