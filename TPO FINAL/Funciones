def ordena(lst_titulos, lst_generos, lst_duraciones, lst_salas, lst_butacas, lst_entradas, lst_valores, lst_estados):
    '''Ordena los titulos por cantidad de entradas o por orden alfabetico en el caso de necesitarlo'''
    # METODO DE BURBUJEO
    n = len(lst_titulos)
    for i in range(n - 1):  # Cuenta las pasadas completas
        for j in range(n - 1 - i):  # Recorre comparando el elemento j con j+1
            # Dentro de la condicion logica se lleva a cabo un "Swapeo", es equivalente a usar un aux pero mas comprimido y en una sola linea
            if lst_entradas[j] < lst_entradas[j + 1] or (lst_entradas[j] == lst_entradas[j + 1] and lst_titulos[j] > lst_titulos[j + 1]):
                lst_titulos[j],   lst_titulos[j+1] = lst_titulos[j+1],   lst_titulos[j]
                lst_generos[j],   lst_generos[j+1] = lst_generos[j+1],   lst_generos[j]
                lst_duraciones[j], lst_duraciones[j+1] = lst_duraciones[j+1],lst_duraciones[j]
                lst_salas[j],     lst_salas[j+1] = lst_salas[j+1],     lst_salas[j]
                lst_butacas[j], lst_butacas[j+1] = lst_butacas[j+1], lst_butacas[j]
                lst_entradas[j],  lst_entradas[j+1] = lst_entradas[j+1],  lst_entradas[j]
                lst_valores[j],   lst_valores[j+1] = lst_valores[j+1],   lst_valores[j]
                lst_estados[j],   lst_estados[j+1] = lst_estados[j+1],   lst_estados[j]

def informe_general(lst_titulos, lst_generos, lst_duraciones, lst_salas, lst_butacas, lst_entradas, lst_valores, lst_estados):
    '''Valida que la lista de titulos no este vacia, genera una matriz con cada uno de los atributos de cada titulo y la imprime'''
    if len(lst_titulos) == 0:
        print(Fore.RED + "No hay peliculas registradas")
        return  # No devuelve nada, solo termina la funcion
    # Return anticipado para que no ejecute todo el resto del codigo sin necesidad
    ordena(lst_titulos, lst_generos, lst_duraciones, lst_salas, lst_butacas, lst_entradas, lst_valores, lst_estados)
    print(Fore.GREEN + "=" * 50)
    print(Fore.GREEN + "     INFORME GENERAL - PELÍCULAS")
    print(Fore.GREEN + "=" * 50)
    matriz = []
    i = 0
    while i < len(lst_titulos):
        fila = [lst_titulos[i], lst_generos[i], lst_duraciones[i],
                lst_salas[i], lst_butacas[i], lst_entradas[i], lst_valores[i], lst_estados[i]]
        # Agrega toda la lista fila de i, i + 1, ... hasta llegar a len(lst_titulos)
        matriz.append(fila)
        i += 1 # No hay que olvidarse de esto ! (Loop infinito)

    # imprimir desde la matriz
    i = 0
    while i < len(matriz):
        print(f"Título:            {matriz[i][0]}")
        generos_texto = "" # Funciona como "Acumulador", pega genero 1 x 1 
        j = 0  # Se usa para recorrer los generos DE ESA PELICULA (Tiene que ser distinta a i, que recorre las peliculas)
        while j < len(matriz[i][1]):
            generos_texto += matriz[i][1][j]
            # i = fila, 1 = Columna j = lista de generos por adentro 


            if j < len(matriz[i][1]) - 1: # Pregunta si j es el ultimo genero DE ESA PELICULA
                generos_texto += ", " # Si hay mas generos agrega la coma entre medio
            j += 1
        # fila = atributos , columnas = distintos atributos
        print(f"Género:            {generos_texto}")
        print(f"Duración:          {matriz[i][2]} minutos")
        print(f"Sala:              {matriz[i][3]}")
        print(f"Butacas disponibles: {matriz[i][4] - matriz[i][5]} de {matriz[i][4]}") # N butacas - N entrdas vendidas 
        print(f"Entradas vendidas: {matriz[i][5]}")
        print(f"Valor entrada:     ${matriz[i][6]}")
        print(f"Estado:            {matriz[i][7]}")
        print("-" * 50)
        i += 1

    input("Presione Enter para volver al menu principal")


