# Programa que lea una cantidad de dinero que desea retirar el cliente e imprima a cuantos billetes equivale
# Existen billetes de $1000 $ 500 $200 $100 $50 y $20
# El resto en monedas
# Desarrolar de tal forma que se minimice la cantidad de billetes entregados por el cajero

billetes1000 = 0
billetes500 = 0
billetes200 = 0
billetes100 = 0
billetes50 = 0
billetes20 = 0
monedas = 0

monto = float(input("Cantidad a retirar: $"))
while monto < 0:
    print("Monto invalido, intentelo nuevamente")
    monto = float(input("Cantidad a retirar: $"))

while monto > 0:
    if monto > 1000:
        billetes1000 += 1
        monto = monto - 1000
    elif monto < 1000 and monto >= 500:
        billetes500 += 1
        monto = monto - 500
    elif monto < 500 and monto >= 200:
        billetes200 += 1
        monto = monto - 200
    elif monto < 200 and monto >= 100:
        billetes100 += 1
        monto = monto - 100
    elif monto < 100 and monto >= 50:
        billetes50 += 1
        monto = monto - 50
    elif monto < 50 and monto >= 20:
        billetes20 += 1
        monto = monto - 20
    elif monto < 20:
        monedas += 1
        monto = monto - 1

print("Cantidad de billetes de $1000:", billetes1000)
print("Cantidad de billetes de $500:", billetes500)
print("Cantidad de billetes de $200:", billetes200)
print("Cantidad de billetes de $100:", billetes100)
print("Cantidad de billetes de $50:", billetes50)
print("Cantidad de billetes de $20:", billetes20)
print("Cantidad de monedas de $1:", monedas)


