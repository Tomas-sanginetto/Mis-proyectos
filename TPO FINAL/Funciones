def eliminar_genero_catalogo(lst_generos_disponibles, lst_generos):
    '''Permite elegir un genero del catalogo y lo elimina unicamente si ninguna pelicula lo esta usando'''
    if len(lst_generos_disponibles) == 0:
        print(Fore.RED + "No existen generos disponibles!")
        return 

    indice = seleccionar_opcion(lst_generos_disponibles, "Seleccione el genero a eliminar del catalogo:")
    genero = lst_generos_disponibles[indice]
    en_uso = False
    for i in range(len(lst_generos)):
        if genero in lst_generos[i]:
            en_uso = True
    if en_uso:
        print(Fore.RED + "No se puede eliminar: hay peliculas que usan ese genero.")
    else:
        lst_generos_disponibles.pop(indice)
        print("Genero eliminado del catalogo con exito!")


def modificar_generos_pelicula(lst_titulos, lst_generos, lst_generos_disponibles):
    '''Permite seleccionar una pelicula y agregarle o quitarle generos, repite hasta que el usuario decida volver'''
    if len(lst_titulos) == 0:
        print(Fore.RED + "No hay peliculas registradas!")
        return # Anticipado para cortar las instrucciones de la funcion

    indice_pelicula = ingresar_titulo("Seleccione la pelicula:", lst_titulos)
    opciones = ["Agregar genero", "Quitar genero", "Volver al menu de generos"]
    indice = seleccionar_opcion(opciones, Fore.GREEN + "Que desea hacer?")
    while indice != 2:  # 2 = ultimo indice de "opciones" (len(opciones) - 1)
        if indice == 0:
            agregar_genero_pelicula(lst_generos, lst_generos_disponibles, indice_pelicula)
