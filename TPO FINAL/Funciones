def titulo_existe(titulo, lst_titulos):
    # Valida la repeticion de titulos con BANDERAS
    '''Verifica si un titulo ya existe en la lista, ignorando mayusculas/minusculas
    y espacios al principio o al final'''
    titulo = titulo.strip().lower() # .strip quita los espacios , saltos de linea, tab (Siempre y cuando sea al principio o final)
    for i in range(len(lst_titulos)):
        if lst_titulos[i].strip().lower() == titulo:
            return True # Return que termina la funcion (NO ruptura de ciclo)
    return False # En caso de que no se hayan encontrado titulos iguales

def ingresar_opcion(opcion):
    '''Valida que la opcion sea un digito dentro del rango numerico 1-7
    y retorna la variable teclado como entero'''
    while opcion.isdigit() == False or int(opcion) < 1 or int(opcion) > 7:
        print(Fore.RED + "La opcion seleccionada no es valida")
        opcion = input("Seleccione una opcion:")
    return int(opcion)


def ingresar_positivo(mensaje):
    '''Validar que el input sea un digito mayor a cero
    y retornar el entero de la variable teclado'''
    num = input(mensaje)
    while num.isdigit() == False or int(num) == 0:
        print(Fore.RED + "Error debe ser un numero positivo")
        num = input(mensaje)
    return int(num)


def ingresar_no_negativo(mensaje):
    '''Validar que el input sea un digito mayor o igual a cero
    y retornar el entero de la variable teclado'''
    num = input(mensaje)
    while num.isdigit() == False or int(num) < 0:
        print(Fore.RED + "Error, debe ser un número entero no negativo")
        num = input(mensaje)
    return int(num)


def ingresar_duracion(): # Sin parametro porque siempre se usa en el mismo contexto 
    '''Pide las horas y los minutos por separado, valida que los minutos
    esten entre 0 y 59 y que la duracion total no sea cero,
    y retorna la duracion total calculada en minutos'''
    horas = ingresar_no_negativo("Ingrese las horas: ")
    minutos = ingresar_no_negativo("Ingrese los minutos: ")
    while minutos > 59 or (horas == 0 and minutos == 0): # Valida que no sea valor nulo (De ambos) y que los minutos vayan HASTA 59
        if minutos > 59:
            print(Fore.RED + "Los minutos deben estar entre 0 y 59")
        else:
            print(Fore.RED + "La duracion no puede ser cero")
        horas = ingresar_no_negativo("Ingrese las horas: ")
        minutos = ingresar_no_negativo("Ingrese los minutos: ")
    return horas * 60 + minutos


def es_numero_decimal(cad):
    '''Arma una copia del texto sin el punto decimal (las cadenas son inmutables)
    y verifica que haya como maximo un punto y que el resto sean solo digitos'''
    nueva = ""  # se construye la copia caracter por caracter
    for i in range(len(cad)): # cada caracter en un string tiene un indice IMPORTANTE ! 
        if cad[i] != ".": # si es "." no se copia a la nueva cadena
            nueva += cad[i]
    return cad.count(".") <= 1 and nueva.isdigit()

def ingresar_valor_entrada(mensaje):
    '''Pide el precio validando que sea un numero no negativo (permite decimales)
    y retorna el valor original convertido a float'''
    cad = input(mensaje)
    while es_numero_decimal(cad) == False:
        print(Fore.RED + "Error, debe ingresar un numero valido")
        cad = input(mensaje)
    return float(cad)


def ingresar_titulo(mensaje, lst_titulos):
    '''Muestra la lista de peliculas disponibles, pide al usuario que seleccione una
    y retorna el indice de la pelicula seleccionada'''
    return seleccionar_opcion(lst_titulos, mensaje)


def validar_titulo(mensaje):
    '''Pide al usuario ingresar el nombre de una nueva pelicula, validando que no quede vacio
    y retorna el nombre ingresado'''
    titulo = input(mensaje).strip() # Para que no sea vacio
    while titulo == "": # Evitando titulos vacios
        print(Fore.RED + "No se ingreso ningun titulo, intentelo denuevo")
        titulo = input(mensaje).strip()
    return titulo


def ingresar_genero(mensaje, lst_generos_disponibles):
    '''Muestra en pantalla cada genero de la lista, pide ingresar el genero
    y retorna el genero elegido de la lista'''
    lst_mostrar = lst_generos_disponibles+ ["Agregar nuevo genero"]
    indice = seleccionar_opcion(lst_mostrar, mensaje)
    if indice == len(lst_generos_disponibles):
        return crear_genero_nuevo(lst_generos_disponibles)
    else:
        return lst_generos_disponibles[indice]


def ingresar_estado(mensaje):
    '''Muestra los posibles estados de la pelicula, pide ingresar el estado
    y retorna el estado ingresado'''
    opciones = ["En cartelera", "Proximo estreno", "Funcion especial", "Finalizada"]
    indice = seleccionar_opcion(opciones, mensaje)
    return opciones[indice]
    


def ingresar_estado_registro(mensaje):  # Se usa cuando se registra una nueva peli (No puede ser estado = Finalizada)
    '''Muestra los posibles estados en el registro de una pelicula, pide ingresar el estado
    y retorna el estado ingresado'''
    opciones = ["En cartelera", "Proximo estreno", "Funcion especial"]
    indice = seleccionar_opcion(opciones, mensaje)
    return opciones[indice]


