def registrar_pago(total):
    '''Solicita la forma de pago: con tarjeta aplica un recargo del 10% y en
    efectivo calcula el vuelto con la menor cantidad de billetes posible.
    Retorna True si el pago se completo y False si se cancelo'''
    opciones_pago = ["Efectivo", "Tarjeta de credito"]
    indice = seleccionar_opcion(opciones_pago, "Seleccione la forma de pago:")

    if indice == 1:  # Tarjeta de credito
        total_con_recargo = round(total * 1.10, 2)  # El ", 2" conserva los centavos
        print(f"Recargo del 10% aplicado. Total a pagar: ${total_con_recargo}")
        return True

    # Efectivo: se acumula lo entregado hasta cubrir el total
    restante = total
    while restante > 0:
        entregado = ingresar_no_negativo(f"Importe a pagar: ${restante}. Ingrese el importe entregado (0 para cancelar): ")
        if entregado == 0:
            print("Pago cancelado.")
            return False
        restante = round(restante - entregado, 2)  # round evita errores de coma flotante
        if restante > 0:
            print(f"Aun falta pagar: ${restante}")

    vuelto = -restante  # restante quedo en 0 o negativo, el vuelto es lo positivo
    if vuelto > 0:
        print(f"Vuelto: ${vuelto}")
        denominaciones = [20000, 10000, 5000, 2000, 1000, 500, 200, 100, 50, 20, 10]
        restante_billetes = int(vuelto)  # Parte entera: los billetes no tienen centavos
        monedas = round(vuelto - restante_billetes, 2)  # Centavos que no llegan a billete
        for i in range(len(denominaciones)):
            cantidad = restante_billetes // denominaciones[i]  # Cuantos billetes de este valor entran
            if cantidad > 0:
                print(f"{cantidad} billete(s) de ${denominaciones[i]}")
                restante_billetes = restante_billetes % denominaciones[i]  # Lo que falta repartir
        if restante_billetes + monedas > 0:  # Lo que queda debajo de $10 va en monedas
            print(f"${round(restante_billetes + monedas, 2)} en monedas")
    return True


def registrar_venta(lst_titulos, lst_butacas, lst_entradas, lst_valores, lst_estados):
    '''Registra la venta de entradas de una pelicula: valida el estado y las
    butacas disponibles, pide la cantidad y cobra con registrar_pago;
    solo confirma la venta si el pago se completo'''
    if len(lst_titulos) == 0:
        print(Fore.RED + "No hay peliculas registradas.")
        return

    indice = ingresar_titulo("Seleccione una pelicula:", lst_titulos)

    if lst_estados[indice] != "En cartelera" and lst_estados[indice] != "Funcion especial":
        print(Fore.RED + "Solo se venden entradas de peliculas En cartelera o Funcion especial.")
        return

    disponibles = lst_butacas[indice] - lst_entradas[indice]  # El stock se calcula, no se guarda
    if disponibles == 0:
        print(Fore.RED + "Funcion agotada, no quedan entradas disponibles.")
        return

    print(f"Entradas disponibles: {disponibles}")
    cantidad = ingresar_positivo("Ingrese cantidad de entradas a vender: ")
    while cantidad > disponibles:  # Avisa y vuelve a preguntar, no expulsa al usuario
        print(Fore.RED + f"No hay entradas suficientes, quedan {disponibles}")
        cantidad = ingresar_positivo("Ingrese cantidad de entradas a vender: ")

    total = round(cantidad * lst_valores[indice], 2) # Redondea a dos decimales 
    print(f"Total a pagar: ${total}")

    if registrar_pago(total):  # Solo se suman las entradas si el pago se completo
        lst_entradas[indice] += cantidad
        print("Venta registrada correctamente.")
    else:
        print("Venta cancelada.")
