def obtener_mes_en_texto(a):
    if a == 1:
        return"Enero"
    elif a == 2:
        return"Febrero"
    elif a == 3:
        return"Marzo"
    elif a == 4:
        return"Abril"
    elif a == 5:
        return"Mayo"
    elif a == 6:
        return"Junio"
    elif a == 7:
        return"Julio"
    elif a == 8:
        return"Agosto"
    elif a == 9:
        return"Septiembre"
    elif a == 10:
        return"Octubre"
    elif a == 11:
        return"Noviembre"
    elif a == 12:
        return"Diciembre"
    else:
        return ""


def main():
    mes = int(input("Ingrese el numero:"))
    while mes < 1 or mes > 12:
        print("Numero de mes invalido, intente denuevo")
        mes = int(input("Ingrese el numero:"))
    resultado = obtener_mes_en_texto(mes)
    print("El resultado es:", resultado)


main()
