matriz5 = []
valor = 1

for i in range(n):
    fila = []
    for l in range(n):
        if (i + l) % 2 != 0:
            fila.append(valor)
            valor += 1
        else:
            fila.append(0)

    matriz5.append(fila)

imprimirmatriz(matriz5)

