# C)
matriz3 = []

for i in range(n):
    fila = []
    valor = n - i

    for l in range(n):
        if l <= i:
            fila.append(valor)
        else:
            fila.append(0)

    matriz3.append(fila)

imprimirmatriz(matriz3)
print("="*40)
# D
matriz4 = []

for i in range(n):
    fila = []
    valor = 2 ** (n - 1 - i)

    for l in range(n):
        fila.append(valor)

    matriz4.append(fila)

imprimirmatriz(matriz4)

print("=" * 40)
