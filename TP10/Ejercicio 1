# F
matriz6 = []
valor = 1
for i in range(n):
    fila = [0] * n
    for l in range(n - 1, -1, -1):
        if i + l >= n - 1:
            fila[l] = valor
            valor += 1
    matriz6.append(fila)
imprimirmatriz(matriz6)
