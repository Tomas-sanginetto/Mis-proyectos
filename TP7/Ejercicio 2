# Diseniar una funcion para mostrar un titulo entre dos lineas de asteriscos

def asteriscos(titulo, y):
    print("*" * y)
    print(titulo)
    print("*" * y)

def main():
    titulo = input("Ingrese el mensaje a mostrar: ")
    y = int(input("Ingrese la cantidad de asteriscos: "))
    asteriscos(titulo, y)

main()

