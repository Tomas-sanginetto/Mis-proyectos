# Programa que permita ingresar por teclado numeros e informar:
# Si la cantidad de numeros ingresadas es par o impar (sin usar contadores)
# Finalizar la lectura con -1
par = True

num = float(input("Ingrese cualquier numero: "))

while num != -1:
    par = not par
    num = float(input("Ingrese cualquier numero: "))

if par:
    print("La cantidad de numeros ingresados es par")
else:
    print("La cantidad de numeros ingresados es impar")

