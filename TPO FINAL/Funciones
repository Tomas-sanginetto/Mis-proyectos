def modificar_pelicula(lst_titulos, lst_generos, lst_duraciones, lst_salas, lst_butacas, lst_entradas, lst_valores, lst_estados):
    '''Valida que la lista de titulos no este vacia, permite seleccionar una pelicula 
    y modificar sus atributos, repite hasta que el usuario decida volver'''
    if len(lst_titulos) == 0:
        print(Fore.RED + "No hay peliculas registradas.")
        return

    indice = ingresar_titulo("Seleccione la pelicula a modificar:", lst_titulos)

    opciones_modificar()
    opcion = input("Seleccione una opcion: ")
    while opcion.isdigit() == False or int(opcion) < 1 or int(opcion) > 8:
        print(Fore.RED + "Opcion invalida")
        opcion = input("Seleccione una opcion: ")
    opcion = int(opcion)

    while opcion != 8:  # 8 = Volver al menu principal
        if opcion == 1:
            nuevo_titulo = validar_titulo("Ingrese el nuevo titulo: ")
            while titulo_existe(nuevo_titulo, lst_titulos):
                print(Fore.RED + "Error: esa pelicula ya existe. Ingrese un titulo diferente.")
        
                nuevo_titulo = validar_titulo("Ingrese el nuevo titulo: ")
            lst_titulos[indice] = nuevo_titulo

        elif opcion == 2:
            lst_duraciones[indice] = ingresar_duracion()

        elif opcion == 3:
            lst_salas[indice] = ingresar_positivo("Ingrese el nuevo numero de sala: ")

        elif opcion == 4:
            entradas = ingresar_no_negativo("Ingrese las nuevas entradas vendidas: ")
            while entradas > lst_butacas[indice]:  # No se pudo vender mas que la capacidad de la sala
                print(Fore.RED + "Las entradas vendidas no pueden superar las butacas de la sala")
                entradas = ingresar_no_negativo("Ingrese las nuevas entradas vendidas: ")
            lst_entradas[indice] = entradas

        elif opcion == 5:
            lst_valores[indice] = ingresar_valor_entrada("Ingrese el nuevo valor de entrada: ")

        elif opcion == 6:
            lst_estados[indice] = ingresar_estado("Ingrese el nuevo estado:")

        elif opcion == 7:
            butacas = ingresar_positivo("Ingrese la nueva capacidad de la sala: ")
            while butacas < lst_entradas[indice]:  # La capacidad no puede quedar debajo de lo ya vendido
                print(Fore.RED + "La capacidad no puede ser menor a las entradas ya vendidas")
                butacas = ingresar_positivo("Ingrese la nueva capacidad de la sala: ")
            lst_butacas[indice] = butacas

        print("Modificacion realizada con exito!")
        opciones_modificar()
        opcion = input("Seleccione una opcion: ")
        while opcion.isdigit() == False or int(opcion) < 1 or int(opcion) > 8:
            print(Fore.RED + "Opcion invalida")
            opcion = input("Seleccione una opcion: ")
        opcion = int(opcion)


