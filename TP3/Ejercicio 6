# Programa que pida un numero e indique que mes es
# Validar que no sea un valor invalido

num = int(input("Ingrese un numero de mes:"))

while num < 1 or num > 12:
    print("Numero de mes no encontrado, intentelo nuevamente!")
    num = int(input("Ingrese un numero de mes:"))

if num == 1:
    print("Tu mes es enero")
elif num == 2:
    print("Tu mes es febrero")
elif num == 3:
    print("Tu mes es marzo")
elif num == 4:
    print("Tu mes es abril")
elif num == 5:
    print("Tu mes es mayo")
elif num == 6:
    print("Tu mes es junio")
elif num == 7:
    print("Tu mes es julio")
elif num == 8:
    print("Tu mes es agosto")
elif num == 9:
    print("Tu mes es septiembre")
elif num == 10:
    print("Tu mes es octubre")
elif num == 11:
    print("Tu mes es noviembre")
elif num == 12:
    print("Tu mes es diciembre")


